{
  "name": "portal",
  "version": "0.1.1",
  "description": "Portal — A beautiful web portal browser",
  "main": "src/main.js",
  "scripts": {
    "build": "node build.js",
    "start": "node build.js && electron .",
    "dev": "node build.js && electron . --dev",
    "dist": "node build.js && electron-builder --publish never",
    "release": "npm run dist && node scripts/generate-release-hash.js"
  },
  "author": "Portal",
  "license": "MIT",
  "build": {
    "appId": "com.portal.browser",
    "productName": "Portal",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "build.js",
      "package.json"
    ],
    "mac": {
      "icon": "src/icons/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  }
}
